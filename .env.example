# Copia este archivo como .env.local y rellena los valores

# PostgreSQL local (arranca con: docker-compose up -d)
DATABASE_URL=postgresql://iuce:iuce2024@localhost:5432/iuce_reservas

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=cambia-este-secret-en-produccion

# Resend (envío de magic links)
# https://resend.com - plan gratis: 100 emails/día
RESEND_API_KEY=re_placeholder
EMAIL_FROM=IUCE Reservas <onboarding@resend.dev>

# Modo desarrollo: "true" habilita mock login (sin enviar emails reales)
NEXT_PUBLIC_USE_MOCK_AUTH=true
